# Kedere — copy to .env and fill in. NEVER commit .env.
# Deployer wallet (must hold Monad testnet MON from https://faucet.monad.xyz)
DEPLOYER_PRIVATE_KEY=

# Two demo resident wallets for the seed script (also need faucet MON)
RESIDENT1_PRIVATE_KEY=
RESIDENT2_PRIVATE_KEY=

# Monad testnet
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
CHAIN_ID=10143

# Optional: explorer verification key (leave blank if using --verifier sourcify)
ETHERSCAN_API_KEY=

# Copy to web/.env.local.

# Sign-in (email / social / external wallet) via Privy.
# Create a free app at https://dashboard.privy.io — the App ID is a public
# client id, safe to ship in the frontend.
VITE_PRIVY_APP_ID=

# Deployed EstateFund (set after `forge script Deploy`).
VITE_CONTRACT_ADDRESS=0xYourDeployedEstateFundAddress
VITE_DEPLOY_BLOCK=0

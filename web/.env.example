# Public (browser)
NEXT_PUBLIC_CONTRACT_ADDRESS=0xYourDeployedEstateFundAddress
NEXT_PUBLIC_DEPLOY_BLOCK=0
NEXT_PUBLIC_WC_PROJECT_ID=

# Supabase Postgres. DATABASE_URL = SESSION pooler (port 5432) for low latency;
# DIRECT_URL = same (or direct) for migrations. The transaction pooler (6543) works
# but adds ~750ms/query on free tier, so prefer 5432 for this workload.
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres

# Auth — random 32-byte hex (openssl rand -hex 32)
SESSION_SECRET=

# Secret gating /api/sync (cron/manual indexer). Generate: openssl rand -hex 32
CRON_SECRET=

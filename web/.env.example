# Copy to web/.env.local.

# WalletConnect project id — optional. Injected wallets (MetaMask etc.) work
# without it; needed for WalletConnect / mobile-wallet QR. Free at cloud.reown.com.
VITE_WC_PROJECT_ID=

# Deployed EstateFund (set after `forge script Deploy`).
VITE_CONTRACT_ADDRESS=0xYourDeployedEstateFundAddress
VITE_DEPLOY_BLOCK=0
